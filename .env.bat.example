rem ================================================================
rem  Tool Launcher - 環境設定ファイルのサンプル
rem ================================================================
rem  このファイルを .env.bat という名前でコピーして、
rem  ご自身の環境に合わせて編集してください。
rem
rem  .env.bat は .gitignore により Git 管理対象外です。
rem  個人のパスや設定が GitHub に公開されることはありません。
rem
rem ----------------------------------------------------------------
rem  設定可能な環境変数
rem ----------------------------------------------------------------
rem  TOOLS_PRE_COMMAND
rem    メニュー起動前に実行するコマンドのフルパス。
rem    仮想環境の activate スクリプトなどを指定します。
rem    不要な場合はこの行をコメントアウトしてください。
rem
rem  TOOLS_PYTHON
rem    使用する Python 実行ファイルのフルパス。
rem    PATH に python が通っている場合は設定不要です。
rem ================================================================

rem ── 仮想環境の activate ──────────────────────────────────────────
rem set "TOOLS_PRE_COMMAND=C:\path\to\.venv\Scripts\activate.bat"

rem ── Python 実行ファイルのパス ─────────────────────────────────────
rem set "TOOLS_PYTHON=C:\Python311\python.exe"
